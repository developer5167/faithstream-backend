{
  "scripts": {
    "start": "NODE_ENV=production node src/server.js",
    "dev": "NODE_ENV=development nodemon src/server.js",
    "createadmin": "nodemon scripts/create-admin.js",
    "resetProdDb": "NODE_ENV=production node src/resetDatabase.js",
    "resetDevDb": "NODE_ENV=development node src/resetDatabase.js",
    "backup:dev": "NODE_ENV=development node -r dotenv/config -e \"require('./src/services/backup.service').runBackup().then(() => console.log('✅ Local Backup Finished')).catch(console.error)\"",
    "backup:prod": "NODE_ENV=production node -r dotenv/config -e \"require('./src/services/backup.service').runBackup().then(() => console.log('✅ AWS S3 Backup Finished')).catch(console.error)\"",
    "restore:dev": "NODE_ENV=development node scripts/restore-backup.js",
    "restore:prod": "NODE_ENV=production node scripts/restore-from-s3.js"
  },
  "name": "faithstream-backend",
  "version": "1.0.0",
  "main": "src/server.js",
  "license": "",
  "author": "",
  "type": "commonjs",
  "description": "Backend for FaithStream music streaming platform",
  "keywords": [
    "music",
    "streaming",
    "backend",
    "faithstream"
  ],
  "repository": {
    "type": "git",
    "url": "git+ssh://"
  },
  "dependencies": {
    "aws-sdk": "^2.1693.0",
    "axios": "^1.13.5",
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "firebase-admin": "^13.6.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.1",
    "nodemon": "^3.1.11",
    "pg": "^8.17.2",
    "rate-limit-redis": "^4.3.1",
    "razorpay": "^2.9.6",
    "redis": "^5.11.0",
    "uuid": "^13.0.0",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0"
  }
}
